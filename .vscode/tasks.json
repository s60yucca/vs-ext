{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build claude-code-model-mapper",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/claude-code-model-mapper"
      },
      "problemMatcher": [
        "$tsc"
      ],
      "detail": "Compile the Claude Code Model Mapper extension"
    },
    {
      "label": "Build & Install VSIX",
      "type": "shell",
      "command": "npm run release:patch && npm run install:vsix",
      "options": {
        "cwd": "${workspaceFolder}/claude-code-model-mapper"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
