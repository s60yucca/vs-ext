{
  "name": "claude-code-model-mapper",
  "displayName": "Claude Code Model Mapper",
  "description": "Map Claude Code models to alternative LLM providers via a local proxy server",
  "version": "1.0.3",
  "publisher": "thohoang",
  "icon": "images/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCodeModelMapper.enableMapper",
        "title": "Enable Mapper (Use Mapper Config)",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.disableMapper",
        "title": "Disable Mapper (Use Claude Subscription)",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.toggleMapper",
        "title": "Toggle Mapper / Claude Subscription",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.startProxy",
        "title": "Start Proxy",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.stopProxy",
        "title": "Stop Proxy",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.toggleDebugLogging",
        "title": "Toggle Debug Logging",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.clearDebugLogs",
        "title": "Clear Debug Logs",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.openTrafficPanel",
        "title": "Open Traffic Panel",
        "category": "Claude Code Model Mapper"
      },
      {
        "command": "claudeCodeModelMapper.openConfigPanel",
        "title": "Open Config Panel",
        "category": "Claude Code Model Mapper"
      }
    ],
    "configuration": {
      "title": "Claude Code Model Mapper",
      "properties": {
        "claudeCodeModelMapper.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Model Mapper. When disabled, restore Claude Code environment settings so new sessions use the Claude subscription."
        },
        "claudeCodeModelMapper.proxyPort": {
          "type": "number",
          "default": 3456,
          "description": "Port cho proxy server. Nếu bị chiếm, sẽ thử port tiếp theo."
        },
        "claudeCodeModelMapper.proxyPortRangeEnd": {
          "type": "number",
          "default": 3466,
          "description": "Port tối đa trong dải thử."
        },
        "claudeCodeModelMapper.debugLoggingEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Write metadata-only proxy diagnostics to a rotating local log. Enable only while debugging."
        },
        "claudeCodeModelMapper.modelConfigs": {
          "type": "array",
          "default": [],
          "description": "Danh sách cấu hình ánh xạ model.",
          "items": {
            "type": "object",
            "properties": {
              "sourceModel": {
                "type": "string",
                "description": "Tên model Claude Code gốc"
              },
              "targetModel": {
                "type": "string",
                "description": "Tên model thực tế để xử lý request"
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Bật/tắt mapping này"
              }
            },
            "required": [
              "sourceModel",
              "targetModel"
            ]
          }
        },
        "claudeCodeModelMapper.lmProvider": {
          "type": "object",
          "default": {
            "baseUrl": "https://openrouter.ai/api/v1"
          },
          "description": "Cấu hình LM Provider.",
          "properties": {
            "baseUrl": {
              "type": "string",
              "description": "Base URL của LM Provider"
            },
            "nativeAnthropic": {
              "type": "boolean",
              "default": false,
              "description": "Bypass OpenAI format conversion. Set to true if the provider supports native Anthropic Messages API."
            }
          }
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCodeModelMapper",
          "title": "Model Mapper",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "claudeCodeModelMapper": [
        {
          "type": "webview",
          "id": "claudeCodeModelMapper.trafficPanel",
          "name": "Traffic Panel"
        },
        {
          "type": "webview",
          "id": "claudeCodeModelMapper.configPanel",
          "name": "Config Panel"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test out/test/*.test.js",
    "release:patch": "vsce package patch --no-git-tag-version --allow-missing-repository",
    "release:minor": "vsce package minor --no-git-tag-version --allow-missing-repository",
    "install:vsix": "\"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --install-extension ${npm_package_name}-${npm_package_version}.vsix --force",
    "release:github": "gh release create v${npm_package_version} ${npm_package_name}-${npm_package_version}.vsix --title \"Release v${npm_package_version}\" --generate-notes"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "fast-check": "^3.15.0",
    "typescript": "^5.9.3"
  }
}
